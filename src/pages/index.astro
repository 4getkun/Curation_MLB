---
import Base from "../layouts/Base.astro";
import FeaturedNews from "../components/FeaturedNews.astro";
import NewsRow from "../components/NewsRow.astro";
import TeamLinkRow from "../components/TeamLinkRow.astro";
import TopicChipLink from "../components/TopicChipLink.astro";
import { allNews, newsGeneratedAt, formatGeneratedAt, newsForPlayer } from "../lib/news";
import { alTeams, nlTeams, teams, needsContrastRing, LEAGUE_LABELS, getTeam } from "../lib/teams";
import { players } from "../lib/players";
import { topics } from "../lib/topics";
import { withBase } from "../lib/url";

const [featured, ...rest] = allNews;
const latest = rest.slice(0, 5);
const dataUrl = withBase("/data/news-index.json");
const teamsForClient = teams.map((t) => ({ id: t.id, short: t.short, color: t.color }));

const playerCards = players.map((player) => {
  const team = getTeam(player.teamId);
  const count = newsForPlayer(player.id).length;
  return { player, team, count };
});
---

<Base title="Curation MLB" description="広告ゼロで読める、日本人メジャーリーガーの所属球団を中心としたMLB(メジャーリーグベースボール)最新ニュース・まとめキュレーションサイト。">
  <!-- Hero -->
  <section style="background-color:var(--hero-bg); color:var(--hero-text); position:relative; overflow:hidden;">
    <div class="container-page relative" style="padding:76px 24px 56px;">
      <div style={`width:44px; height:3px; background-color:var(--accent); margin-bottom:22px;`}></div>
      <p
        class="font-bold uppercase m-0"
        style="font-size:12px; letter-spacing:0.14em; color:var(--hero-muted); margin-bottom:18px;"
      >
        広告ゼロ・トラッキングなしのMLBキュレーション
      </p>
      <h1
        class="font-display font-black text-balance m-0"
        style="font-size:clamp(32px,5vw,58px); line-height:1.12; letter-spacing:-0.01em; margin-bottom:20px; max-width:720px;"
      >
        日本人メジャーリーガーの活躍を、<br class="hidden sm:block" />ノイズなく一箇所で。
      </h1>
      <p class="m-0" style="font-size:16px; line-height:1.8; color:var(--hero-muted); max-width:520px; margin-bottom:34px;">
        大谷翔平選手をはじめ日本人メジャーリーガー全選手の所属球団ニュースと話題を、英語圏の野球専門メディアから自動収集して球団・選手別に整理。記事は英語原文のまま掲載しています。バナー広告も追跡もない、読むことだけに集中できるキュレーションサイトです。
      </p>
      <div class="flex flex-wrap gap-3" style="margin-bottom:28px;">
        <a
          href={withBase("/player/")}
          class="no-underline font-bold"
          style="background-color:var(--accent); color:#fff; padding:14px 28px; border-radius:2px; font-size:14px;"
        >
          日本人選手から探す
        </a>
        <a
          href={withBase("/news/")}
          class="no-underline font-bold"
          style="background:none; color:var(--hero-text); border:1px solid rgb(255 255 255 / 28%); padding:14px 28px; border-radius:2px; font-size:14px;"
        >
          最新ニュース一覧を見る
        </a>
      </div>
      {newsGeneratedAt && (
        <p class="m-0" style="font-size:12px; color:var(--hero-muted);">
          最終更新: {formatGeneratedAt(newsGeneratedAt)}（自動更新）
        </p>
      )}
    </div>
  </section>

  <!-- 日本人メジャーリーガー(サイトの核となるセクション。トップ近くに配置) -->
  <section id="jp-players" style="border-bottom:1px solid var(--border);">
    <div class="container-page" style="padding:48px 24px;">
      <div class="flex items-baseline justify-between" style="margin-bottom:6px;">
        <h2 class="font-display font-black m-0" style="font-size:22px; color:var(--text);">日本人メジャーリーガー</h2>
        <a href={withBase("/player/")} class="no-underline font-bold" style="font-size:13px; color:var(--accent);">全選手を見る →</a>
      </div>
      <p style="font-size:14px; color:var(--text-muted); margin-bottom:24px;">
        現在MLBでプレーする日本人選手{players.length}名の所属球団と、関連ニュースの件数をひと目で確認できます。
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5" style="gap:1px; background-color:var(--border); border:1px solid var(--border);">
        {playerCards.map(({ player, team, count }) => {
          const ring = team ? needsContrastRing(team.color) : false;
          return (
            <a
              href={withBase(`/player/${player.id}/`)}
              class="block no-underline"
              style="background-color:var(--card-bg); padding:18px 16px;"
            >
              <span
                class="inline-block rounded-[3px]"
                style={`width:12px; height:12px; background-color:${team?.color ?? "var(--text-faint)"};${ring ? " box-shadow:0 0 0 1px var(--text-faint);" : ""}`}
              ></span>
              <p class="font-bold m-0" style="font-size:14px; color:var(--text); margin-top:10px;">{player.name}</p>
              <p class="m-0" style="font-size:11px; color:var(--text-faint); margin-top:2px;">{player.englishName}</p>
              <p class="m-0" style="font-size:12px; color:var(--text-muted); margin-top:8px;">{team?.short ?? "所属未定"}</p>
              <p class="m-0" style="font-size:11px; color:var(--text-faint); margin-top:4px;">{count > 0 ? `ニュース${count}件` : "ニュース準備中"}</p>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- マイ球団(お気に入り球団)の最新ニュース。localStorageに保存された球団があれば
       クライアントサイドでこの下に描画し、無ければヒントだけ表示する。 -->
  <section id="my-team-section" style="border-bottom:1px solid var(--border);">
    <div class="container-page" style="padding:24px;">
      <p id="my-team-hint" style="font-size:13px; color:var(--text-muted); margin:0;">
        ヘッダーの「★ マイ球団」から応援球団を選ぶと、ここにその球団の最新ニュースだけを表示できます。
        <a href="#team-access" class="link-underline" style="color:var(--accent); font-weight:bold;">球団を選ぶ →</a>
      </p>
      <div id="my-team-result" class="hidden">
        <div class="flex items-baseline justify-between" style="margin-bottom:16px;">
          <h2 id="my-team-heading" class="font-display font-black m-0" style="font-size:20px; color:var(--text);"></h2>
          <a id="my-team-link" href="#" class="no-underline font-bold" style="font-size:13px; color:var(--accent);">すべて見る →</a>
        </div>
        <div id="my-team-list"></div>
        <p id="my-team-empty" class="hidden" style="font-size:13px; color:var(--text-muted);">
          まだこの球団のニュースが取得されていません。次回の自動更新をお待ちください。
        </p>
      </div>
    </div>
  </section>

  <!-- Featured + Latest -->
  <section class="container-page" style="padding:56px 24px;">
    <div
      class="flex items-baseline justify-between"
      style="border-bottom:2px solid var(--text); padding-bottom:12px; margin-bottom:28px;"
    >
      <h2 class="font-display font-black m-0" style="font-size:22px; color:var(--text);">最新ニュース</h2>
      <a href={withBase("/news/")} class="no-underline font-bold" style="font-size:13px; color:var(--accent);">すべて見る →</a>
    </div>

    {featured ? (
      <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-10">
        <FeaturedNews item={featured} />
        <div>
          {latest.map((item) => (
            <NewsRow item={item} variant="compact" />
          ))}
        </div>
      </div>
    ) : (
      <p style="font-size:14px; color:var(--text-muted);">
        まだニュースが取得されていません。GitHub Actions の自動収集ワークフローが実行されると、ここに最新記事が並びます。
      </p>
    )}
  </section>

  <!-- Team access -->
  <section id="team-access" style="background-color:var(--card-bg); border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:56px 0;">
    <div class="container-page">
      <h2 class="font-display font-black m-0" style="font-size:22px; color:var(--text); margin-bottom:6px;">球団から探す</h2>
      <p style="font-size:14px; color:var(--text-muted); margin-bottom:28px;">
        アメリカン・リーグ、ナショナル・リーグ全10球団のニュースをチームごとに確認できます。
        気になる球団があれば、ヘッダーの「★ マイ球団」から登録するとトップページに専用セクションが表示されます。
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
        <div>
          <p class="font-bold" style="font-size:11px; letter-spacing:0.1em; color:var(--text-faint); margin-bottom:10px;">{LEAGUE_LABELS.AL}</p>
          {alTeams.map((team) => (
            <TeamLinkRow team={team} />
          ))}
        </div>
        <div>
          <p class="font-bold" style="font-size:11px; letter-spacing:0.1em; color:var(--text-faint); margin-bottom:10px;">{LEAGUE_LABELS.NL}</p>
          {nlTeams.map((team) => (
            <TeamLinkRow team={team} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Topic access -->
  <section class="container-page" style="padding:44px 24px;">
    <h2 class="font-display font-black m-0" style="font-size:22px; color:var(--text); margin-bottom:6px;">話題から探す</h2>
    <p style="font-size:14px; color:var(--text-muted); margin-bottom:20px;">球団の枠を超えて、移籍・故障・契約更改などの話題ごとにニュースを横断できます。</p>
    <div class="flex flex-wrap gap-2">
      {topics.map((topic) => (
        <TopicChipLink topic={topic} />
      ))}
    </div>
  </section>

  <!-- Value props (hairline grid) -->
  <section class="container-page" style="padding:56px 24px;">
    <div class="grid grid-cols-1 sm:grid-cols-3" style="gap:1px; background-color:var(--border); border:1px solid var(--border);">
      <div class="hairline-cell">
        <span class="inline-block rounded-[2px]" style="width:10px; height:10px; background-color:var(--accent);"></span>
        <p class="font-bold m-0" style="font-size:15px; color:var(--text); margin:14px 0 6px;">広告・トラッキング一切なし</p>
        <p class="m-0" style="font-size:13px; color:var(--text-muted); line-height:1.7;">バナー広告や追跡スクリプトを使わず、記事を読むことに集中できます。</p>
      </div>
      <div class="hairline-cell">
        <span class="inline-block rounded-[2px]" style="width:10px; height:10px; background-color:var(--accent);"></span>
        <p class="font-bold m-0" style="font-size:15px; color:var(--text); margin:14px 0 6px;">30分ごとに自動更新</p>
        <p class="m-0" style="font-size:13px; color:var(--text-muted); line-height:1.7;">英語圏の野球専門メディアのRSSを定期的に集約し、日本人選手・球団・話題ごとに自動振り分けしています。</p>
      </div>
      <div class="hairline-cell">
        <span class="inline-block rounded-[2px]" style="width:10px; height:10px; background-color:var(--accent);"></span>
        <p class="font-bold m-0" style="font-size:15px; color:var(--text); margin:14px 0 6px;">高速な静的サイト</p>
        <p class="m-0" style="font-size:13px; color:var(--text-muted); line-height:1.7;">GitHub Pages上の静的サイトとして配信しているため表示が軽快です。</p>
      </div>
    </div>
  </section>
</Base>

<script define:vars={{ dataUrl, teamsForClient, base: import.meta.env.BASE_URL }}>
  (function () {
    var STORAGE_KEY = "mlb-curation-my-team";
    var favoriteId = "";
    try {
      favoriteId = localStorage.getItem(STORAGE_KEY) || "";
    } catch (e) {}

    var hint = document.getElementById("my-team-hint");
    var resultBox = document.getElementById("my-team-result");
    if (!favoriteId) return; // 未設定ならヒント表示のまま何もしない

    var team = teamsForClient.find(function (t) {
      return t.id === favoriteId;
    });
    if (!team) return;

    hint.classList.add("hidden");
    resultBox.classList.remove("hidden");
    document.getElementById("my-team-heading").textContent = "マイ球団: " + team.short + " の最新ニュース";
    document.getElementById("my-team-link").href = base + "team/" + team.id + "/";

    function escapeHtml(str) {
      return (str || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    function formatRelative(pubDate) {
      if (!pubDate) return "";
      var date = new Date(pubDate);
      if (isNaN(date.getTime())) return "";
      var diffMin = Math.floor((Date.now() - date.getTime()) / 60000);
      if (diffMin < 1) return "たった今";
      if (diffMin < 60) return diffMin + "分前";
      var diffHour = Math.floor(diffMin / 60);
      if (diffHour < 24) return diffHour + "時間前";
      var diffDay = Math.floor(diffHour / 24);
      if (diffDay < 7) return diffDay + "日前";
      return date.toLocaleDateString("ja-JP", { month: "short", day: "numeric" });
    }

    fetch(dataUrl)
      .then(function (res) {
        return res.json();
      })
      .then(function (data) {
        var teamNews = data.filter(function (item) {
          return item.teams && item.teams.indexOf(team.id) !== -1;
        });
        var list = document.getElementById("my-team-list");
        var empty = document.getElementById("my-team-empty");
        if (teamNews.length === 0) {
          empty.classList.remove("hidden");
          return;
        }
        list.innerHTML = teamNews
          .slice(0, 5)
          .map(function (item) {
            var title = item.titleJa && item.titleJa.trim() ? item.titleJa : item.title;
            return (
              '<a href="' +
              escapeHtml(item.link) +
              '" target="_blank" rel="noopener noreferrer nofollow" class="flex items-start no-underline" style="gap:14px; padding:14px 0; border-bottom:1px solid var(--border); color:inherit;">' +
              '<span class="inline-block shrink-0 rounded-full" style="width:8px; height:8px; background-color:' +
              team.color +
              '; margin-top:7px;"></span>' +
              '<div class="flex-1 min-w-0">' +
              '<h4 class="font-bold leading-snug m-0 mb-1.5" style="font-size:15px; color:var(--text);">' +
              escapeHtml(title) +
              "</h4>" +
              '<p class="m-0" style="font-size:12px; color:var(--text-faint);">' +
              escapeHtml(item.source) +
              " · " +
              formatRelative(item.pubDate) +
              "</p></div></a>"
            );
          })
          .join("");
      })
      .catch(function () {
        /* オフライン等で取得に失敗した場合は、ヒント表示のまま静かに諦める */
      });
  })();
</script>
