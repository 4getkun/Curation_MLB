---
import Base from "../../layouts/Base.astro";
import PlayerLinkRow from "../../components/PlayerLinkRow.astro";
import { teams, needsContrastRing } from "../../lib/teams";
import { playersForTeam } from "../../lib/players";

const teamGroups = teams
  .map((team) => ({ team, players: playersForTeam(team.id) }))
  .filter((group) => group.players.length > 0);
---

<Base
  title="日本人メジャーリーガー"
  description="MLBでプレーする日本人選手一覧。所属球団ごとのニュースをまとめて確認できます。"
>
  <section class="container-page" style="padding:44px 24px 64px;">
    <h1 class="font-display font-black m-0" style="font-size:28px; color:var(--text); margin-bottom:6px;">日本人メジャーリーガー</h1>
    <p style="font-size:14px; color:var(--text-muted); margin-bottom:32px;">
      現在MLBでプレーする日本人選手を、所属球団ごとに確認できます。選手名をクリックするとその選手に関するニュースだけを絞り込めます。
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-8">
      {teamGroups.map(({ team, players }) => {
        const ring = needsContrastRing(team.color);
        return (
          <div>
            <p class="flex items-center gap-2 font-bold" style="font-size:13px; color:var(--text); margin-bottom:10px;">
              <span class="inline-block rounded-[3px]" style={`width:12px; height:12px; background-color:${team.color};${ring ? " box-shadow:0 0 0 1px var(--text-faint);" : ""}`}></span>
              {team.name}
            </p>
            {players.map((player) => (
              <PlayerLinkRow player={player} />
            ))}
          </div>
        );
      })}
    </div>
  </section>
</Base>
